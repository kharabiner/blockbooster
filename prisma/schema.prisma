generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  organizedEvents  Event[]           @relation("OrganizerEvents")
  booths           Booth[]
  templates        Template[]
  slotApplications SlotApplication[]
  announcements    Announcement[]
  chatMessages     ChatMessage[]     @relation("ChatAuthor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Feature Modules (개발자가 코드로 등록) ─────────────────────────────────────

model FeatureModule {
  id           String @id
  name         String
  description  String
  configSchema String // JSON Schema string

  templateModules TemplateModule[]
  eventModules    EventModule[]
  moduleData      ModuleData[]
}

// ─── Templates ────────────────────────────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  thumbnail   String?
  isPublic    Boolean  @default(false)
  slotLayout  String   @default("[]") // JSON: 기본 슬롯 레이아웃
  gridRows    Int      @default(10)
  gridCols    Int      @default(10)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  modules TemplateModule[]
  events  Event[]
}

model TemplateModule {
  id     String @id @default(cuid())
  config String @default("{}") // JSON: 모듈별 설정

  templateId String
  template   Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  moduleId String
  module   FeatureModule @relation(fields: [moduleId], references: [id])

  @@unique([templateId, moduleId])
}

// ─── Events ───────────────────────────────────────────────────────────────────

model Event {
  id          String      @id @default(cuid())
  shortCode   String      @unique
  title       String
  description String?
  thumbnail   String?
  location    String?
  startAt     DateTime
  endAt       DateTime
  gridRows    Int         @default(10)
  gridCols    Int         @default(10)
  status      String      @default("DRAFT") // DRAFT | PUBLISHED | ONGOING | ENDED
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  organizerId String
  organizer   User   @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: Cascade)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])

  slots         BoothSlot[]
  announcements Announcement[]
  modules       EventModule[]
}

// ─── Booths ───────────────────────────────────────────────────────────────────

model Booth {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  mediaUrls   String   @default("[]") // JSON array of URLs
  shortCode   String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  slots        BoothSlot[]
  applications SlotApplication[]
}

// ─── BoothSlots (그리드 위 자리) ──────────────────────────────────────────────

model BoothSlot {
  id     String @id @default(cuid())
  posX   Int
  posY   Int
  width  Int    @default(2)
  height Int    @default(2)
  color  String @default("#6366f1")
  label  String?

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  boothId String?
  booth   Booth?  @relation(fields: [boothId], references: [id], onDelete: SetNull)

  applications SlotApplication[]
  invitations  SlotInvitation[]
  moduleData   ModuleData[]
  visits       Visit[]
  chatMessages ChatMessage[]
}

// ─── Event Modules (이벤트 직속 모듈 — 템플릿 없이도 사용 가능) ──────────────

model EventModule {
  id     String @id @default(cuid())
  config String @default("{}") // JSON: 모듈별 설정

  eventId String
  event   Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)

  moduleId String
  module   FeatureModule @relation(fields: [moduleId], references: [id])

  @@unique([eventId, moduleId])
}

// ─── Slot 연결 (신청/초대) ────────────────────────────────────────────────────

model SlotApplication {
  id        String   @id @default(cuid())
  message   String?
  status    String   @default("PENDING") // PENDING | ACCEPTED | REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slotId String
  slot   BoothSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  boothId String
  booth   Booth  @relation(fields: [boothId], references: [id], onDelete: Cascade)

  applicantId String
  applicant   User   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
}

model SlotInvitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  status    String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED
  expiresAt DateTime
  createdAt DateTime @default(now())

  slotId String
  slot   BoothSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
}

// ─── Module Data ──────────────────────────────────────────────────────────────

model ModuleData {
  id        String   @id @default(cuid())
  data      String   @default("{}") // JSON
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boothSlotId String
  boothSlot   BoothSlot @relation(fields: [boothSlotId], references: [id], onDelete: Cascade)

  moduleId String
  module   FeatureModule @relation(fields: [moduleId], references: [id])

  @@unique([boothSlotId, moduleId, userId])
}

// ─── Visit ────────────────────────────────────────────────────────────────────

model Visit {
  id        String   @id @default(cuid())
  visitorId String?
  createdAt DateTime @default(now())

  boothSlotId String
  boothSlot   BoothSlot @relation(fields: [boothSlotId], references: [id], onDelete: Cascade)
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  eventId  String
  event    Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  slotId   String
  slot     BoothSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?     @relation("ChatAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  authorName String? // 비로그인 사용자 이름 저장용
}
